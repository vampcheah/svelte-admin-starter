		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^22.19.20",
		"bits-ui": "^2.18.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-svelte": "^3.14.0",
		"formsnap": "^2.0.1",
