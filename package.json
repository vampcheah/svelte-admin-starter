{
	"name": "svelte-admin-starter",
	"description": "Production-grade SvelteKit + Svelte 5 + Tailwind v4 + shadcn-svelte admin dashboard starter — frontend-only, mock data, clone-and-go.",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.17.0",
